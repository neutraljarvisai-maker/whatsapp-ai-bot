# VECTA AI Provider Configuration

# Current selection: gemini | ollama
VECTA_LLM_PROVIDER=ollama

# Google Gemini Configuration (Required if provider is gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Ollama Configuration (Required if provider is ollama)
VECTA_OLLAMA_MODEL=qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434

# System / Backend Configuration
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
JARVIS_USER_ID=default_user

# WhatsApp / Twilio Configuration
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
GROQ_API_KEY=your_groq_key_if_using_whatsapp_legacy
